	pages = {243--253},
}

@article{smith_multi-radar_2016,
	title = {Multi-{Radar} {Multi}-{Sensor} ({MRMS}) {Severe} {Weather} and {Aviation} {Products}: {Initial} {Operating} {Capabilities}},
